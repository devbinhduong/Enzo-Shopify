<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>
  {{ 'component-search.css' | asset_url | stylesheet_tag }}
  {{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
</noscript>

{%- liquid
  assign sec_stts = section.settings

  assign has_menu_tab = false
  assign check_menu_tab = section.blocks | where: 'type', 'menu_tab'
  if check_menu_tab.size > 0
    assign has_menu_tab = true
  endif

  assign order = 'multi_tab_menu,logo,mobile_logo,menu,message,account,search,localization,mobile_search,actions,custom_button'

  if shop.customer_accounts_enabled
    assign order = 'multi_tab_menu,mobile_search,logo,mobile_logo,menu,message,account,search,localization,actions,custom_button'
  endif

  assign rows = 'top,bottom' | split: ','
  assign search_style = 'none'

  if section.settings.show_search
    assign search_style = 'modal'
  endif

  if sec_stts.enable_transparent_header_home and template.name == 'index'
    assign transparent = 'always'
    assign transparent_color_scheme = sec_stts.home_color_scheme
  elsif sec_stts.enable_transparent_header_product and template.name == 'product'
    assign transparent = 'always'
    assign transparent_color_scheme = sec_stts.product_color_scheme
  elsif sec_stts.enable_transparent_header_collection and template.name == 'collection'
    assign transparent = 'always'
    assign transparent_color_scheme = sec_stts.collection_color_scheme
  endif

  if sec_stts.enable_sticky_header == 'always'
    assign sticky = 'always'
  elsif sec_stts.enable_sticky_header == 'scroll-up'
    assign sticky = 'scroll-up'
  endif

  if transparent and sticky
    assign transparent = 'not-sticky'
  endif

  assign header_wrapper = 'header-component'

  if transparent
    if transparent_color_scheme == 'inverse'
      assign transparent_color_scheme = 'color-' | append: section.settings.color_scheme_transparent
    else
      assign transparent_color_scheme = 'color-' | append: section.settings.color_scheme_top
    endif
  endif

  capture logo
    render 'header-logo', header_settings: sec_stts, blocks: section.blocks, has_menu_tab: has_menu_tab
  endcapture

  capture menu
    render 'header-menu-snippet', header_settings: sec_stts, blocks: section.blocks, menu_gap: sec_stts.menu_gap
  endcapture

  capture mobile_menu
    render 'header-menu-snippet', header_settings: sec_stts, blocks: section.blocks, variant: 'mobile'
  endcapture

  capture account
    render 'header-account', sec_stts: sec_stts, custom_header_utility: sec_stts.custom_header_utility, header_utility_size: sec_stts.header_utility_size, header_utility_font: sec_stts.header_utility_font, header_utility_weight: sec_stts.header_utility_weight, header_utility_line_height: sec_stts.header_utility_line_height, header_utility_letter_spacing: sec_stts.header_utility_letter_spacing, header_utility_case: sec_stts.header_utility_case, header_utility_wrap: sec_stts.header_utility_wrap
  endcapture

  capture account_mobile
    render 'header-account', sec_stts: sec_stts, custom_header_utility: sec_stts.custom_header_utility, header_utility_size: sec_stts.header_utility_size, header_utility_font: sec_stts.header_utility_font, header_utility_weight: sec_stts.header_utility_weight, header_utility_line_height: sec_stts.header_utility_line_height, header_utility_letter_spacing: sec_stts.header_utility_letter_spacing, header_utility_case: sec_stts.header_utility_case, header_utility_wrap: sec_stts.header_utility_wrap, extra_class: 'lg:none'
  endcapture

  capture actions
    render 'header-functions', sec_stts: sec_stts, blocks: section.blocks, enable_cart: true, enable_wishlist: settings.show_wishlist, custom_header_utility: sec_stts.custom_header_utility, header_utility_size: sec_stts.header_utility_size, header_utility_font: sec_stts.header_utility_font, header_utility_weight: sec_stts.header_utility_weight, header_utility_line_height: sec_stts.header_utility_line_height, header_utility_letter_spacing: sec_stts.header_utility_letter_spacing, header_utility_case: sec_stts.header_utility_case, header_utility_wrap: sec_stts.header_utility_wrap
  endcapture

  capture actions_mobile
    render 'header-functions', sec_stts: sec_stts, blocks: section.blocks, enable_cart: true, enable_wishlist: settings.show_wishlist, custom_header_utility: sec_stts.custom_header_utility, header_utility_size: sec_stts.header_utility_size, header_utility_font: sec_stts.header_utility_font, header_utility_weight: sec_stts.header_utility_weight, header_utility_line_height: sec_stts.header_utility_line_height, header_utility_letter_spacing: sec_stts.header_utility_letter_spacing, header_utility_case: sec_stts.header_utility_case, header_utility_wrap: sec_stts.header_utility_wrap, extra_class: 'lg:none'
  endcapture

  if shop.customer_accounts_enabled
    assign search_class = 'max-md:hidden'
  endif

  capture search
    render 'header-search', style: search_style, input_id: 'Search-In-Modal', class: search_class, display_type: sec_stts.search_display_type, sec_stts: sec_stts, custom_header_utility: sec_stts.custom_header_utility, header_utility_size: sec_stts.header_utility_size, header_utility_font: sec_stts.header_utility_font, header_utility_weight: sec_stts.header_utility_weight, header_utility_line_height: sec_stts.header_utility_line_height, header_utility_letter_spacing: sec_stts.header_utility_letter_spacing, header_utility_case: sec_stts.header_utility_case, header_utility_wrap: sec_stts.header_utility_wrap
  endcapture

  capture multi_tab_menu
    render 'header-multi-site', settings: sec_stts, blocks: section.blocks, menu_gap: sec_stts.menu_gap
  endcapture

  capture message
    render 'header-message', settings: sec_stts, blocks: section.blocks
  endcapture

  capture custom_button
    render 'header-custom-button', settings: sec_stts
  endcapture

  if shop.customer_accounts_enabled
    render 'account-drawer'
  endif

  # Handle localization positioning
  if sec_stts.localization_position == 'left'
    if sec_stts.search_position == 'left'
      if shop.customer_accounts_enabled
        assign order = 'multi_tab_menu,mobile_search,logo,mobile_logo,menu,message,account,search,localization,actions,custom_button'
      else
        assign order = 'multi_tab_menu,logo,mobile_logo,menu,message,account,search,localization,mobile_search,actions,custom_button'
      endif
    else
      if shop.customer_accounts_enabled
        assign order = 'multi_tab_menu,mobile_search,logo,mobile_logo,menu,message,account,search,localization,actions,custom_button'
      else
        assign order = 'multi_tab_menu,logo,mobile_logo,menu,message,account,search,localization,mobile_search,actions,custom_button'
      endif
    endif
  else
    if sec_stts.search_position == 'left'
      if shop.customer_accounts_enabled
        assign order = 'multi_tab_menu,mobile_search,logo,mobile_logo,menu,message,account,search,localization,actions,custom_button'
      else
        assign order = 'multi_tab_menu,logo,mobile_logo,menu,message,account,search,localization,mobile_search,actions,custom_button'
      endif
    endif
  endif

  assign header_actions_order = sec_stts.header_actions_order | default: 'account,search,localization,actions'
  assign order = order | replace: 'account,search,localization,actions', header_actions_order

  # Handle logo row
  if sec_stts.logo_row == 'bottom'
    capture mobile_logo
      render 'header-logo', header_settings: sec_stts, blocks: section.blocks, class: 'lg:none'
    endcapture
  endif

  # Skip mobile search under specific conditions:
  # Always render if search_row is bottom
  # Don't render when shop.customer_accounts_enabled is false and search_position is left
  assign skip_mobile_search = false
  if shop.customer_accounts_enabled == false and sec_stts.search_position == 'left' and search_style != 'none'
    assign skip_mobile_search = true
  endif

  if sec_stts.search_row == 'bottom' or search_style != 'none' and skip_mobile_search == false
    # Mobile search duplicate for when search is not in the right order for mobile layout
    capture mobile_search
      render 'header-search', class: 'lg:none', input_id: 'Search-In-Modal-Mobile', style: search_style, variant: 'mobile'
    endcapture
  endif

  
  assign show_language = sec_stts.show_language
  if localization.available_languages.size <= 1
    assign show_language = false
  endif

  assign show_country = sec_stts.show_country
  if localization.available_countries.size <= 1
    assign show_country = false
  endif
  
  if show_country or show_language
    assign show_flag = false
    if sec_stts.country_selector_style == true
      assign show_flag = true
    endif
    capture localization_markup
      render 'dropdown-localization', show_country: show_country, show_language: show_language, country_style: show_flag, localization_position: sec_stts.localization_position, localization_type: sec_stts.localization_type, hide_mobile: true, section_id: section.id
    endcapture
  endif

  assign bottom_row_blocks = ''

  if section.settings.menu_row == 'bottom'
    assign bottom_row_blocks = bottom_row_blocks | append: 'menu,'
  endif

  if search_style != 'none'
    if section.settings.search_row == 'bottom'
      assign bottom_row_blocks = bottom_row_blocks | append: 'search,'
    endif
  endif

  if section.settings.show_country or section.settings.show_language
    if section.settings.localization_row == 'bottom'
      assign bottom_row_blocks = bottom_row_blocks | append: 'localization,'
    endif
  endif

  assign bottom_row_blocks = bottom_row_blocks | split: ',' | compact

  if section.settings.section_height == 'compact'
    assign header_height_class = ' header--compact'
  endif

  if bottom_row_blocks.size > 0 and section.settings.color_scheme_top.settings.background.rgb == section.settings.color_scheme_bottom.settings.background.rgb and section.settings.divider_width == 0
    assign collapse_header_paddings_class = 'header--collapse-row-paddings'
  endif

  assign class = 'header'

  if transparent_color_scheme
    assign class = class | append: ' ' | append: transparent_color_scheme
  endif

  if sec_stts.color_scheme_top.settings.background.alpha != 1
    assign class = class | append: ' ' | append: 'header--inherit-color-scheme-on-menu-open'
  endif

  if header_height_class
    assign class = class | append: ' ' | append: header_height_class
  endif

  if collapse_header_paddings_class
    assign class = class | append: ' ' | append: collapse_header_paddings_class
  endif

  if sec_stts.reveal_logo_on_sticky
    assign class = class | append: ' ' | append: 'header--reveal-logo-on-sticky'
  endif
-%}


<{{ header_wrapper }}
  class="
    header-wrapper
    {{ class }}
    {% if sec_stts.show_line_separator %} header-wrapper--border-bottom{% endif %}
    {% if has_menu_tab %} has-menu-tab{% endif %}
  "
  {% if sticky %}
    data-sticky-type="{{ sticky }}"
  {% endif %}
  {% if transparent %}
    transparent="{{ transparent }}"
  {% endif %}
  id="header-component"
>
  <div class="row-group{% if sec_stts.enable_shadow %} row-group--shadow{% endif %}"
  style="
  --padding-block-start-top: {{ sec_stts.padding-block-start-top }}px;
  --padding-block-end-top: {{ sec_stts.padding-block-end-top }}px;
  --padding-block-start-bottom: {{ sec_stts.padding-block-start-bottom }}px;
  --padding-block-end-bottom: {{ sec_stts.padding-block-end-bottom }}px;
  --button-type-font-link: var(--font-{{ sec_stts.button_type_font_link }}--family);--button-font-size-link: {{ sec_stts.button_type_size_link }};--button-font-weight-link: {{ sec_stts.button_font_weight_link }}; --text-transform: {{ sec_stts.case }};
  --button-type-font-link-2: var(--font-{{ sec_stts.button_type_font_link_2 }}--family);--button-font-size-link-2: {{ sec_stts.button_type_size_link_2 }};--button-font-weight-link-2: {{ sec_stts.button_font_weight_link_2 }}; --text-transform-link-2: {{ sec_stts.case_link_2 }};
  --button-type-font-link-3: var(--font-{{ sec_stts.button_type_font_link_3 }}--family);--button-font-size-link-3: {{ sec_stts.button_type_size_link_3 }};--button-font-weight-link-3: {{ sec_stts.button_font_weight_link_3 }}; --text-transform-link-3: {{ sec_stts.case_link_3 }};
  {% render 'gap-style', value: sec_stts.gap, name: 'gap-items' %}
  "
  >
    {% for row in rows %}
      {% liquid
        assign scheme = 'color_scheme_' | append: row
        assign class = 'header__row header__row--[row] color-[row_scheme] section section--full-width-margin section--[section-width]' | replace: '[row]', row | replace: '[row_scheme]', sec_stts[scheme] | replace: '[section-width]', sec_stts.section_width | append: ' color-tablet-' | append: sec_stts.color_scheme_top_mb | append: ' color-mobile-' | append: sec_stts.color_scheme_top_mb
        case row
          when 'top'
            assign first = mobile_menu

            if bottom_row_blocks.size > 0 and section.settings.divider_size == 'page-width'
              assign class = class | append: ' divider--page-width'
            endif

            if bottom_row_blocks.size > 0
              assign border_bottom_setting_id = 'divider_width'
            else
              assign border_bottom_setting_id = 'border_width'
            endif
          when 'bottom'
            assign first = ''
            assign class = class | append: ' max-md:hidden'

            assign border_bottom_setting_id = 'border_width'
        endcase

        assign style = '--border-bottom-width: [width]px; ' | replace: '[width]', section.settings[border_bottom_setting_id]
        
        if section.settings.section_width == 'custom'
          assign page_width_custom = section.settings.page_width_custom | divided_by: 10
          assign style = style | append: '--page-content-width: [page_width_custom]rem; --page-width: calc(var(--page-content-width) + var(--page-margin) * 2);' | replace: '[page_width_custom]', page_width_custom
        endif

        if row == 'top'
          assign style = style | append: '--border-bottom-width-mobile: [width]px; ' | replace: '[width]', section.settings.border_width
        endif
      %}

      {% capture content %}
        {% render 'header-row',
          row: row,
          order: order,
          settings: sec_stts,
          first: first,
          logo: logo,
          mobile_logo: mobile_logo,
          menu: menu,
          actions: actions,
          actions_mobile: actions_mobile,
          localization: localization_markup,
          account: account,
          account_mobile: account_mobile,
          search: search,
          mobile_search: mobile_search,
          multi_tab_menu: multi_tab_menu,
          message: message,
          custom_button: custom_button,
          color: scheme
        %}
      {% endcapture %}

      {% assign content = content | strip %}
      {% if content != blank %}
        <div
          class="{{ class | strip }}"
          {%- if style != blank -%}
            style="{{ style | strip }}"
          {%- endif -%}
        >
          <div class="header__columns items-{{ sec_stts.align_items }} spacing-style">
            {{ content }}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</{{ header_wrapper }}>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% elsif settings.logo_svg %}
      "logo": {{ settings.logo_svg | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{% if sec_stts.localization_type == 'sidebar' %}
  {% render 'custom-drawer' %}
{% endif %}

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

