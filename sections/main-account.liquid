{{ 'customer.css' | asset_url | stylesheet_tag }}

<script src="{{ 'customer.js' | asset_url }}" defer></script>
<script src="{{ 'main-account.js' | asset_url }}" defer="defer"></script>

<div
  class="section customer account spacing color-{{ section.settings.color_scheme }}"
  style="
    --p-spacing-t: {{ section.settings.padding_top }}px;
    --p-spacing-b: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="accountTabs">
    <ul class="accountTabs__list list-unstyled" role="list">
      <li class="accountTabs__item active" role="listitem">
        <button class="button button-unstyled" type="button" role="tab" aria-selected="true" aria-controls="accountTabs-1" id="accountTabs-1-tab">
          My profile
        </button>
      </li>
      <li class="accountTabs__item" role="listitem">
        <button class="button button-unstyled" type="button" role="tab" aria-selected="false" aria-controls="accountTabs-2" id="accountTabs-2-tab">
          My order history
        </button>
      </li>
      <li class="accountTabs__item" role="listitem">
        <button class="button button-unstyled" type="button" role="tab" aria-selected="false" aria-controls="accountTabs-3" id="accountTabs-3-tab">
          My wishlist
        </button>
      </li>
      <li class="accountTabs__item" role="listitem">
        <button class="button button-unstyled" type="button" role="tab" aria-selected="false" aria-controls="accountTabs-4" id="accountTabs-4-tab">
          KS Glowie Club
        </button>
      </li>
      <li class="accountTabs__item" role="listitem">
        <button class="button button-unstyled" type="button" role="tab" aria-selected="false" aria-controls="accountTabs-2" id="accountTabs-logout-tab">
          <a href="{{ routes.account_logout_url }}">
            {{ 'customer.log_out' | t }}
          </a>
        </button>
      </li>
    </ul>

    <div class="accountTabs__contents">
      <div class="accountTabs__content active" id="accountTabs-1" role="tabpanel" aria-labelledby="accountTabs-1-tab">
        <h2 class="accountTabs__title">My Addresses</h2>

        <div id="address-loader-container">
          <p>Loading addresses...</p> 
        </div>
        
      </div>
      <div class="accountTabs__content" id="accountTabs-2" role="tabpanel" aria-labelledby="accountTabs-2-tab">
        <h2 class="accountTabs__title">{{ 'customer.orders.title' | t }}</h2>

        <div class="orders-table">
          <div class="orders-table__head">
            <div class="orders-table__head__item orders-table__head__item--date">Date</div>
            <div class="orders-table__head__item orders-table__head__item--number">Order number</div>
            <div class="orders-table__head__item orders-table__head__item--status">Payment status</div>
            <div class="orders-table__head__item orders-table__head__item--total">Total</div>
            <div class="orders-table__head__item orders-table__head__item--arrow"></div>
            <div class="orders-table__head__item"></div>
          </div>

          {% for order in customer.orders %}
            <div class="order-accordion" data-order-id="{{ order.id }}">
              <div class="order-accordion__summary" type="button" aria-expanded="false">
                <span class="order-col order-col--date">{{ order.created_at | date: "%d/%m/%Y" }}</span>
                <span class="order-col order-col--name">{{ order.name }}</span>
                <span class="order-col order-col--status">
                  <span class="order-status-badge order-status-badge--{{ order.financial_status }}">{{ order.financial_status_label }}</span>
                </span>
                <span class="order-col order-col--total">{{ order.total_price | money }}</span>
                <span class="order-col order-col--chevron">
                  <svg class="order-chevron-icon" xmlns="http://www.w3.org/2000/svg" width="12" height="8" viewBox="0 0 12 8" fill="none">
                    <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </span>
                <span class="order-col order-col--action">
                  <button type="button" class="button-secondary order-again-btn"  data-order-id="{{ order.id }}" data-line-items="{{ order.line_items | map: 'variant_id' | join: ',' }}">
                    Order Again
                  </button>
                </span>
              </div>
              <div class="order-accordion__products" hidden>
                <div class="order-accordion__products-inner">
                  <swiper-component
                    class="order-products-swiper"
                    data-slides-per-view="2"
                    data-space-between="16"
                    data-breakpoints='{"640":{"slidesPerView":3},"990":{"slidesPerView":4},"1200":{"slidesPerView":6}}'
                  >
                    <div class="swiper">
                      <ul class="swiper-wrapper order-products-list list-unstyled">
                        {% for line_item in order.line_items %}
                          <li class="swiper-slide order-product-item">
                            <a href="{{ line_item.product.url }}" class="order-product-item__link">
                              <div class="order-product-item__image">
                                {%- if line_item.image -%}
                                  {{ line_item.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: line_item.product.title }}
                                {%- else -%}
                                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                {%- endif -%}
                              </div>
                              <p class="order-product-item__title">{{ line_item.product.title }}</p>
                              <span class="order-product-item__price">{{ line_item.final_price | money }}</span>
                            </a>
                          </li>
                        {% endfor %}
                      </ul>
                      <div class="swiper-btns-wrap order-swiper-btns">
                        {%- render 'swiper-button' -%}
                      </div>
                    </div>
                  </swiper-component>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="accountTabs__content" id="accountTabs-3" role="tabpanel" aria-labelledby="accountTabs-3-tab">
        <h2 class="accountTabs__title">My Wishlist</h2>
        <div id="wishlist-loader-container"></div>
      </div>
      <div class="accountTabs__content" id="accountTabs-4" role="tabpanel" aria-labelledby="accountTabs-4-tab" data-club-page-url="{{ section.settings.club_page_url }}">
        <h2 class="accountTabs__title">KS Glowie Club</h2>
        <div id="ks-glowie-club-loader-container"></div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:names.account",
  "settings": [
    {
      "type": "header",
      "content": "t:content.colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "url",
      "id": "club_page_url",
      "label": "KS Glowie Club Page URL"
    },
    {
      "type": "header",
      "content": "t:content.section_padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.bottom",
      "default": 36
    }
  ]
}
{% endschema %}
