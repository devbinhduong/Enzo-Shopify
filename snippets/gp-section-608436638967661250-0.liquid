      <style id="custom-css-g8wjPiZGOZ">
        .gp-scroll-links .gp-active, .gp-scroll-links .gp-active * {
    font-weight: 600 !important;
    color: #FD76A9 !important;
    font-size: 13px !important; /* Added font-size 14px */
}

      </style>
    
      <script id="custom-js-g8wjPiZGOZ">
        try {
          (function( jQuery ){
  $(window).scroll(doStickyMenu);
 
  function doStickyMenu(){
    var tArray = $('.gp-title-page');
    for(var i = 0; i < tArray.length; i++){
        
        var tArrOffset = $(tArray[i]).offset().top - 80 -82; 
      
      if( ( !tArray[i + 1] && tArrOffset < window.scrollY ) || (  tArrOffset < window.scrollY && $(tArray[i + 1]).offset().top -80 -82 > window.scrollY ) ){
        $('.gp-scroll-links a').removeClass('gp-active');
        var id = $(tArray[i]).parents('.gp-target-row').attr('id');
        
        $('.gp-scroll-links a').each(function(){
          if($(this).attr('href') == '#' + id){
            $(this).addClass('gp-active');
          }
        });
        break;
      }
      
    }
    
  }
  

})( window.GemQuery || jQuery );
        } catch(err){}
      </script>
    