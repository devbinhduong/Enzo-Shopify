<div 
  class="card-product__group-item card-wishlist"
  style="--min-w: 3.4rem;"
>
  <wish-list class="block h-full w-full">
    <button
      type="button"
      title="{{ 'content.add' | t }}"
      class="{{ class_button }} wishlist-button w-full"
      data-wishlist
      data-wishlist-handle="{{ card_product.handle }}"
      data-product-id="{{ card_product.id }}"
    >
      {% comment %} <span class="{{ class_text }}">
        <span class="{{ class_text_inner }}">{{ 'content.add' | t }}</span>
      </span> {% endcomment %}
      <span class="svg-wrapper" style="--icon-size: 1.8rem;">
        <svg
          class="wishlist-button__icon"
          aria-hidden="true"
          focusable="false"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 19 18"
          width="19"
          height="18"
        >
          {% render 'icon', icon: 'heart' %}
        </svg>
      </span>
    </button>
  </wish-list>
</div>
