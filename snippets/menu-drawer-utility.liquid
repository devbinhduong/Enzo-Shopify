<div
  class="menu-drawer__utility-links flex justify-center"
  style="--menu-drawer-animation-index: {{ listmenu_size | plus: 1 }};"
>

  {% liquid
    assign show_language = sec_settings.show_language
    if localization.available_languages.size <= 1
      assign show_language = false
    endif

    assign show_country = sec_settings.show_country
    if localization.available_countries.size <= 1
      assign show_country = false
    endif

    assign country_style = sec_settings.country_selector_style
  %}

  {%- if country_style == true -%}
    <link rel="stylesheet" href="{{ 'icon-flag.css' | asset_url }}" media="print" onload="this.media='all'">
  {%- endif -%}

  {%- capture icon_globe -%}
    <svg
      class="icon-globe icon"
      aria-hidden="true"
      focusable="false"
      fill="none"
      viewBox="0 0 50 50"
    >
      {%- render 'icon', icon: 'globe' -%}
    </svg>
  {%- endcapture -%}


  {%- if show_language or show_country or settings.show_wishlist -%}
    {%- if show_language or show_country -%}
      {% comment %} <h3 class="menu-drawer__utility-heading h6" id="HeaderLanguageLabel">
        {%- if show_language and show_country -%}
          {{ 'content.localization_region_and_language' | t }}
        {%- elsif show_language and show_country == false -%}
          {{ 'content.language' | t }}
        {%- elsif show_language == false and show_country -%}
            {{ 'content.country_label' | t }}
        {%- endif -%}
      </h3> {% endcomment %}
      {% comment %} {%- render 'language-country-localization',
        localPosition: 'DrawerHeaderLanguage',
        country_style: country_style,
        show_language: show_language,
        show_country: show_country,
        icon_globe: icon_globe,
        show_back_button: true,
        element: 'drawer',
        section_id: section_id
      -%} {% endcomment %}
      {% render 'dropdown-localization', 
        show_country: show_country, show_language: show_language, 
        country_style: show_flag, localization_position: sec_stts.localization_position, localization_type: sec_stts.localization_type, 
        hide_mobile: false, section_id: section.id %}
    {%- endif -%}
  {%- endif -%}
</div>
