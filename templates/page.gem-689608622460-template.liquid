lang="en" width="863" height="797" data-width="100%" data-height="auto" title="" natural-width="863" natural-height="797"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1742981559295" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1742981559295"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-gemlang="en" data-exc=""><p>1. APPLy & CURE GEL</p></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1742981559342" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1742981559342"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-gemlang="en" data-exc=""><p>Apply the gel nails first and cure them before adding a gem stone</p><p></p></div></div></div><div class="gf_column gf_col-lg-3 gf_col-md-3 gf_col-sm-6 gf_col-xs-12" id="c-1705312628125" data-id="1705312628125"><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1742981559323" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1742981559323" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-xs gf-elm-center-sm gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/2dc9c430-6b1a-47b1-9439-34f35959603a/-/format/auto/-/preview/3000x3000/-/quality/lighter/3.jpg" alt="" class="gf_image" data-gemlang="en" data-width="100%" data-height="auto" title="" width="863" height="797" natural-width="863" natural-height="797"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1742981559359" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1742981559359"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1 gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-cent