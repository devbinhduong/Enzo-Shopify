acing-xl-p-top gf_gs-spacing-xl-p-bottom gf_gs-spacing-lg-m-top gf_gs-border-2525715 gf_equal-height gf_gs-spacing-xl-m-bottom gf_row-gap-15 gf_gs-border-2568289" data-icon="gpicon-row" data-id="1728366114922" data-extraclass="" data-layout-lg="12" data-layout-md="12" data-layout-sm="12" data-layout-xs="12" style="display: flex; flex-wrap: wrap; visibility: visible;" data-row-gap="15px"><div class="gf_column gf_col-lg-12 gf_col-md-12 gf_col-sm-12 gf_col-xs-12" id="c-1721826837725" data-id="1721826837725" style="display: flex; flex-direction: column; justify-content: flex-start; min-height: auto;"><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1728366114981" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1728366114981" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/35ff257d-025a-4e4d-962f-b8f7d35a26e9/-/format/auto/-/preview/3000x3000/-/quality/lighter/100k_shopping_spree_banner.jpg" alt="" class="gf_image gf_gs-corner-corner" data-gemlang="en" data-width="100%" data-height="auto" title="" width="2400" height="468" natural-width="2400" natural-height="468"></div></div><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1728366114948" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1728366114948" data-resolution="3000x3000"><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-lg gf-elm-center-xs" data-exc=""><img src="https://ucarecdn.com/86ef04dc-d49a-4be3-84e0-db8b64051a76/-/format/auto/-/preview/3000x3000/-/quality/lighter/100k_shopping_spree_01.jpg" alt="" class="gf_image gf_gs-corner-corner" data-gemlang="en" data-width="100%" data-height="auto" title="" width="1080" height="1080" natural-width="1080" natural-height="1080"></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1728366114992" class="element-wrap gf_gs-spacing-lg-m-top" data-icon="gpicon-textblock" data-ver="1" data-id="1728366114992"><div class="elm text-edit gf-elm-left gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf_gs-text-paragraph-1" data-gemlang="en" data-exc=""><p>Roll out the red carpet—this one’s for YOU! In celebration of our 100K milestone, we’re granting <strong>exclusive access</strong> to our K-beauty paradise. For the first time ever, we’re opening our doors to a select group of lucky winners, giving you the chance to experience the ultimate K-Beauty fantasy! Picture this: a <strong>1-minute dash</strong> where you can grab every K-beauty product your heart desires—for free! But wait, there’s more! Keep reading to discover what else we have in store.</p><p><br></p></div></div><div data-label="Tabs" data-key="tabs" data-atomgroup="module" id="m-1728366114935" class="module-wrap" data-icon="gpicon-tabs" data-ver="1.0" data-id="1728366114935"><div class="gf_restabs module style3 gf_module-center  gf_restabs_accordion_0" data-activetab="1" data-tabbgcolor="none" data-tabcolor="var(--gf_gs-color2-brand)" data-inactivetabbgcolor="#e0e0e0" data-inactivetabcolor="var(--gf_gs-color3-neutral)" data-bordercolor="var(--gf_gs-color1-accent)" data-bordersize="1px" data-height=""><ul><li class="gf_tab" data-index="1"><span class="item-content" data-index="1" data-key="content"><div data-label="Text Block" id="e-1728366114935-1" class="element-wrap" data-tool="0" data-icon="gpicon-textblock" data-id="1728366114935-1" data-ver="1"><div class="elm text-edit gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><strong>Prizes</strong></div></div></span><span class="gf_tab-bottom"></span></li><li class="gf_tab" data-index="2"><span class="item-content" data-index="2" data-key="content"><div data-label="Text Block" id="e-1728366114935-2" class="element-wrap" data-tool="0" data-icon="gpicon-textblock" data-id="1728366114935-2" data-ver="1"><div class="elm text-edit gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><strong>I want to join</strong></div></div></span><span class="gf_tab-bottom"></span></li><li class="gf_tab" data-index="3"><span class="item-content" data-index="3" data-key="content"><div data-label="Text Block" id="e-1728366115006" class="element-wrap" data-tool="0" data-icon="gpicon-textblock" data-id="1728366115006" data-ver="1"><div class="elm text-edit gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-exc=""><strong>Terms & Conditions</strong></div></div></span><span class="gf_tab-bottom"></span></li></ul><span class="gf_tab-accordion-title"><span></span></span><div data-index="1" data-key="content1" class="item-content gf_tab-panel"><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1728366114861" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1728366114861"><div class="elm text-edit gf-elm-left gf-elm-left-lg gf-elm-left-md gf-elm-left-sm gf-elm-left-xs gf_gs-text-paragraph-1" data-gemlang="en" data-exc=""><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);"><strong>First Grand Prize - The All Inclusive Experience:</strong></p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">One lucky winner from anywhere in Europe & UK will experience the ultimate K-Beauty paradise treatment:</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- Round-trip flight to Eindhoven, the Netherlands</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- 2-night stay at a cozy hotel near our HQ</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- A 1-minute shopping spree at Korean Skincare HQ</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- A delightful lunch and an exclusive tour of our HQ<br><br><strong>Second & Third Prizes - The Friendly Neighbor Experience:</strong></p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">2 winners from the Netherlands will enjoy:</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- A 1-minute shopping spree at Korean Skincare HQ</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- A delightful lunch and an exclusive tour of our HQ</p></div></div></div><span class="gf_tab-accordion-title"><span></span></span><div data-index="2" data-key="content1" class="item-content gf_tab-panel"><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1728366114982" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1728366114982"><div class="elm text-edit gf_gs-text-paragraph-1 gf-elm-left" data-gemlang="en"><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);"><strong>How to enter K-Beauty paradise?</strong><br>- Follow <u><a href="https://www.instagram.com/koreanskincare_official/" class="" target="_blank">Korean Skincare on Instagram</a></u> and like our giveaway post.</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- Comment on the <u><a href="https://www.instagram.com/koreanskincare_official/p/DA3A3YmtIv2/" class="" target="_blank">Shopping Spree Instagram post</a></u> at least 1 product you would want to get if you win.</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- Share the giveaway post on your Instagram story and tag Korean Skincare for a bonus entry.</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);"></p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- Make sure to read the&nbsp;Terms & Conditions&nbsp;carefully<br>- Fill in the application form below<br><span style="text-align: inherit; letter-spacing: 0px;">- For an extra chance at winning, head over to our IG post and comment at least 3 products that you will get whenever you win</span></p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);">- Winners will be announced by email within a week after submissions close</p><p style="font-size: 16px; font-family: Poppins; text-align: inherit!important; color: rgb(35, 35, 35);"></p></div></div><div data-label="Klaviyo" data-key="klaviyo-signup-form" data-atomgroup="module" id="m-1728366114956" class="module-wrap gf_gs-spacing-lg-m-top" data-icon="gpicon-klaviyo" data-ver="1" data-id="1728366114956" style="" data-compile="false"><div class="module gf_module-left-lg gf_module-left-md gf_module-left-sm gf_module-left-xs "><div class="klaviyo-form-SLEy8q"></div></div></div></div><span class="gf_tab-accordion-title"><span></span></span><div data-index="3" data-key="content1" class="item-content gf_tab-panel"><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1728366114921" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1728366114921"><div class="elm text-edit gf-elm-left gf_gs-text-paragraph-1" data-gemlang="en"><h3></h3><p><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">1. Eligibility:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">1.1 The ‘Ticket to K-beauty Paradise Giveaway’ is open to all followers of Korean Skincare who are at least 18 years old at the time of entry. Residents of the European Union, the Netherlands, and the United Kingdom are eligible to participate.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">1.2 There are two amazing prizes to win:</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">- One lucky Grand Prize winner from anywhere in Europe or the UK will receive the "<strong>All-Inclusive Experience</strong>", which includes:</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - Round-trip flight to Eindhoven, The Netherlands.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - A 2-night stay at a cozy hotel near Korean Skincare HQ in Eindhoven, The Netherlands.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - A 1-minute shopping spree at Korean Skincare HQ in Eindhoven, The Netherlands, on November 16, 2024.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - A delightful lunch and an exclusive tour of Korean Skincare HQ in Eindhoven, The Netherlands.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">- Additionally, two lucky winners based in the Netherlands will win the "<strong>Friendly Neighbor Experience</strong>", which includes:</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - A 1-minute shopping spree at Korean Skincare HQ in Eindhoven, The Netherlands, on November 16, 2024.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - A delightful lunch and an exclusive tour of Korean Skincare HQ in Eindhoven, The Netherlands.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">2. Giveaway Period:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">2.1 The Giveaway begins on Tuesday, October 8, 2024, and ends at 11:59 PM (CEST) on Tuesday, October 15, 2024.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">2.2 Entries submitted after this time will not be considered.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">2.3 Winners will be contacted within a week after submissions close.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">3. How to Enter:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">3.1 Follow Korean Skincare (<a href="https://www.instagram.com/koreanskincare_official/" class="">@koreanskincare_official</a>) on Instagram and like our Shopping Spree Instagram post.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">3.2 Comment on the Shopping Spree Instagram post with at least 1 product you'd want to grab if you win.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">3.3 Share the Shopping Spree post on your Instagram story and tag Korean Skincare for a bonus entry.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">3.4 Apply via the application form with your details.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">3.5 No purchase is necessary to enter, and only one entry per person will be accepted.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">3.6 Make sure to read the Terms & Conditions carefully before applying.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">4. Winner Selection & Notification:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">4.1 Two (2) winners based in the Netherlands will be randomly selected from all eligible entries to win the <strong>Friendly Neighbor Experience</strong>.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">4.2 One (1) grand prize winner will be randomly selected from all eligible European and UK entries to win the <strong>All-Inclusive Experience</strong>.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">4.3 All winners will be notified via e-mail within a week after submissions close. The winners must respond within 48 hours to claim their prize, or an alternate winner may be selected.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">4.4 After winners are selected, there will be a contact moment (either via Microsoft Teams or calls) to ensure that all contestants understand the event and prize conditions.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">5. Prizes:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">5.1 <strong>Friendly Neighbor Experience</strong> (Netherlands-based winners):</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">- Two winners based in the Netherlands will receive:</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - A 1-minute shopping spree at Korean Skincare HQ in Eindhoven, The Netherlands, on November 16, 2024.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - A delightful lunch and an exclusive tour of Korean Skincare HQ in Eindhoven, The Netherlands.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">- The winners will be responsible for their travel or accommodation expenses incurred to participate in the shopping spree.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">- Each winner may bring one guest to the event on November 16, 2024. The guest will also receive an exclusive tour and lunch at Korean Skincare HQ in Eindhoven, The Netherlands, but will not participate in the shopping spree.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">5.2 <strong>Grand Prize - All-Inclusive Experience</strong> (European & UK Participants):</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">- One winner will receive a ‘Ticket to K-Beauty Paradise,’ which includes:</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - Round-trip flight tickets from their location to Eindhoven, The Netherlands, for the dates November 15–17, 2024.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - Two (2) nights’ accommodation at a hotel near Korean Skincare HQ in Eindhoven, The Netherlands.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - A 1-minute shopping spree at Korean Skincare HQ in Eindhoven, The Netherlands, on November 16, 2024.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - An exclusive tour and lunch at Korean Skincare HQ in Eindhoven, The Netherlands.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - On November 15, 2024, the winner will have a free day to spend as they like.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">- The grand prize winner may bring one guest for the entire weekend. This guest will receive:</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">&nbsp; &nbsp; - Round-trip flight tickets, two (2) nights' accommodation, an exclusive tour and lunch at Korean Skincare HQ in Eindhoven, The Netherlands, but will not participate in the shopping spree.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">6. Shopping Spree Conditions (Applicable to All Winners):</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">6.1 Winners will have 1 minute to race through our warehouse and collect as many K-beauty products as they can within that time. They will receive all products for free.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">6.2 The shopping spree is limited to in-stock products, and participants may not select more than one of the same product.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">6.3 Once the shopping basket is full, no additional products may be added.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">6.4 Participants based in the Netherlands are responsible for any travel or accommodation expenses to participate in the shopping spree.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">6.5 If a winner cannot attend the shopping spree, the prize may be forfeited, and an alternate winner selected.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">7. Participant Responsibilities:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">7.1 Netherlands-based winners are responsible for their own travel and accommodation expenses.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">7.2 Grand Prize winners are responsible for their transportation to/from the airport and personal expenses during the trip.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">7.3 All winners must inform Korean Skincare of any dietary restrictions or allergies prior to the event.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">8. Prize Conditions:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">8.1 The prizes are non-transferable, non-refundable, and cannot be exchanged for cash or other items.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">8.2 Korean Skincare will provide lunch only on November 16. All other meals during the weekend will be at the participants' expense.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">8.3 On November 16, 2024, the Grand Prize winner and guest will be picked up from their hotel, taken to Korean Skincare HQ in Eindhoven, The Netherlands, and dropped off afterward.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">9. Liability:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">9.1 Korean Skincare shall not be liable for any injuries, losses, or damages resulting from participation in the Giveaway or acceptance, use, or misuse of the prize.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">9.2 The grand prize winner is advised to have adequate travel insurance for the duration of their trip.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">9.3 Korean Skincare reserves the right to modify or cancel the Giveaway due to unforeseen circumstances.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">10. Publicity:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">10.1 By participating, all winners agree to the use of their name, image, and video footage for social media and promotional purposes by Korean Skincare without additional compensation, unless prohibited by law.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">11. Privacy:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">11.1 Any personal information collected during the Giveaway will be used in accordance with Korean Skincare’s Privacy Policy and data protection laws.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">11.2 Personal data will not be disclosed to any third party without the entrant's consent.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">12. Governing Law:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">12.1 The Giveaway and these terms and conditions are governed by the laws of the Netherlands.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">12.2 Any disputes shall be subject to the exclusive jurisdiction of the courts of the Netherlands.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">13. Acceptance of Terms:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">13.1 By entering the Giveaway, participants agree to abide by these terms and conditions and the decisions of Korean Skincare, which are final and binding.</span><br><strong style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">14. Winner Cancellation:</strong><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">14.1 If any winner is unable to attend the event or claim the prize for any reason, they must notify Korean Skincare as soon as possible but no later than 72 hours before the event date (November 16, 2024).</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">14.2 In the event of a cancellation:</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">- <strong>For the Grand Prize Winner (All-Inclusive Experience)</strong>: Korean Skincare reserves the right to either select an alternate winner or cancel the prize entirely. Flight and accommodation costs already incurred by Korean Skincare on behalf of the winner or their guest are non-refundable and will not be compensated.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">- <strong>For Friendly Neighbor Experience Winners</strong>: If a Dutch-based winner cancels, an alternate winner may be selected, or the prize may be forfeited at the discretion of Korean Skincare. Any travel expenses incurred by the winner are non-refundable.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">14.3 Korean Skincare is not responsible for any costs or losses associated with winner cancellations, including but not limited to travel, accommodation, or personal expenses.</span><br><span style="color: inherit; font-family: inherit; font-size: inherit; text-align: inherit; letter-spacing: 0px;">14.4 If Korean Skincare has already booked travel or accommodations for the Grand Prize winner and their guest, and they cancel with less than 72 hours' notice, the winner will be responsible for any cancellation fees or non-refundable charges.</span><br></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p><p></p></div></div></div><div class="gf_clearfix"></div></div></div></div></div></div></div><!--gfsplit--><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1728479887506" class="gf_row gf_gs-spacing-md-m-top gf_gs-spacing-xs-m-bottom" data-icon="gpicon-row" data-id="1728479887506"><div class="gf_column gf_col-lg-12 gf_col-md-12 gf_col-sm-12 gf_col-xs-12" id="c-1721832147748" data-id="1721832147748"><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1728479887606" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1728479887606"><div class="elm text-edit gf-elm-center gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-gemlang="en" data-exc=""><h2 class="gf_gs-text-heading-1">WIN YOUR WISHLIST!</h2></div></div><div data-label="Separator" data-key="separator" data-atomgroup="element" id="e-1728479887579" class="element-wrap" data-icon="gpicon-separator" data-ver="1.0" data-id="1728479887579"><div class="elm gf-elm-center gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs" data-align="left" data-exc=""><hr class="gf_separator"></div></div><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1728479887543" class="gf_row gf_gs-corner-corner gf_gs-spacing-lg-p-left gf_gs-spacing-lg-p-right gf_gs-spacing-xl-p-top gf_gs-spacing-xl-p-bottom gf_gs-spacing-lg-m-top gf_gs-border-2525715 gf_equal-height gf_gs-spacing-xl-m-bottom gf_row-gap-15 gf_gs-border-2568289" data-icon="gpicon-row" data-id="1728479887543" data-extraclass="" data-layout-lg="4+8" data-layout-md="4+8" data-layout-sm="4+8" data-layout-xs="12+12" style="display: flex; flex-wrap: wrap; visibility: visible;" data-row-gap="15p