p><p></p><p></p><p></p></div></div></div></div><!--gfsplit--><div class="element-wrap" data-label="Text Block" id="e-1728036154760" data-icon="gpicon-textblock" data-ver="1" data-id="1728036154760"><div class="elm text-edit gf_gs-text-paragraph-1"></div></div><!--gfsplit--><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1728036154766" class="gf_row gf_gs-spacing-md-m-top gf_gs-spacing-xs-m-bottom" data-icon="gpicon-row" data-id="1728036154766"><div class="gf_column gf_col-lg-12 gf_col-md-12 gf_col-sm-12 gf_col-xs-12" id="c-1721832147748" data-id="1721832147748"><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1728036154773" class="element-wrap" data-icon="gpicon-heading" data-ver="2" data-id="1728036154773"><div class="elm text-edit gf-elm-center gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-gemlang="en" data-exc=""><h2 class="gf_gs-text-heading-1">Win a €100 gift card every day this week!</h2></div></div><div data-label="Separator" data-key="separator" data-atomgroup="element" id="e-1728036154757" class="element-wrap" data-icon="gpicon-separator" data-ver="1.0" data-id="1728036154757"><div class="elm gf-elm-center gf-elm-center-lg gf-elm-center-md gf-elm-center-sm gf-elm-center-xs" data-align="left" data-exc=""><hr class="gf_separator"></div></div><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1728036154824" class="gf_row gf_gs-corner-corner gf_gs-spacing-lg-p-left gf_gs-spacing-lg-p-right gf_gs-spacing-xl-p-top gf_gs-spacing-xl-p-bottom gf_gs-spacing-lg-m-top gf_gs-border-2525715 gf_equal-height gf_gs-spacing-xl-m-bottom gf_row-gap-15 gf_gs-border-2568289" data-icon="gpicon-row" data-id="1728036154824" data-extraclass="" data-layout-lg="4+8" data-layout-md="4+8" data-layout-sm="4+8" data-layout-xs="12+12" style="display: flex; flex-wrap: wrap; visibility: visible;" data-row-gap="15px"><div class="gf_column gf_col-lg-4 gf_col-md-4 gf_col-sm-4 gf_col-xs-12" id="c-1721826837725" d