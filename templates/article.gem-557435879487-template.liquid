en" data-width="30%" data-height="auto" title="" width="800" height="800" natural-width="800" natural-height="800"></div></div><div data-label="Row" data-key="row" data-atomgroup="row" id="r-1654069815769" class="gf_row" data-icon="gpicon-row" data-id="1654069815769" data-extraclass="" data-layout-lg="8+4" data-layout-md="8+4" data-layout-sm="12+12" data-layout-xs="12+12" style=""><div class="gf_column gf_col-lg-8 gf_col-md-8 gf_col-xs-12 gf_col-sm-12" id="c-1654067669120" data-id="1654067669120"><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1654069815781" class="element-wrap" data-icon="gpicon-heading" data-ver="1" data-id="1654069815781" style=""><lt-highlighter contenteditable="false" class="lt--mac-os" data-lt-linked="1" style="display: none; z-index: auto !important;"><lt-div spellcheck="false" class="lt-highlighter__wrapper" style="width: 765.328px !important; height: 44px !important; transform: none !important; transform-origin: 382.664px 22px !important; zoom: 1 !important;"><lt-div class="lt-highlighter__scroll-element" style="top: 0px !important; left: 0px !important; width: 765px !important; height: 53px !important;"><canvas class="lt-highlighter__canvas" width="96" height="40" style="display: none; top: 13px !important; left: 0px !important;"></canvas></lt-div></lt-div></lt-highlighter><div class="elm text-edit gf-elm-center gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-left-lg" data-gemlang="en" data-exc="" data-lt-tmp-id="lt-837624" spellcheck="false" data-gramm="false"><h2 class="gf_gs-text-heading-2"><span style="letter-spacing: 0px; text-align: inherit;"><br></span></h2><h2 class="gf_gs-text-heading-2"><span style="letter-spacing: 0px; text-align: inherit;">Huong</span><br></h2></div></div><div data-label="Heading" data-key="heading" data-atomgroup="element" id="e-1677750676011" class="element-wrap" data-icon="gpicon-heading" data-ver="1" data-id="1677750676011" style=""><lt-highlighter contenteditable="false" class="lt--mac-os" data-lt-linked="1" style="display: none; z-index: auto !important;"><lt-div spellcheck="false" class="lt-highlighter__wrapper" style="width: 765.328px !important; height: 44px !important; transform: none !important; transform-origin: 382.664px 22px !important; zoom: 1 !important;"><lt-div class="lt-highlighter__scroll-element" style="top: 0px !important; left: 0px !important; width: 765px !important; height: 53px !important;"></lt-div></lt-div></lt-highlighter><div class="elm text-edit gf-elm-center gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-left-lg" data-gemlang="en" data-exc="" data-lt-tmp-id="lt-419339" spellcheck="false" data-gramm="false"><h2 class="gf_gs-text-heading-2"><span style="letter-spacing: 0px; text-align: inherit;"><br></span></h2><h2 class="gf_gs-text-heading-2">Warehouse Team</h2></div></div><div data-label="Text Block" data-key="text-block" data-atomgroup="element" id="e-1677751037349" class="element-wrap" data-icon="gpicon-textblock" data-ver="1" data-id="1677751037349"><lt-highlighter contenteditable="false" class="lt--mac-os" data-lt-linked="1" style="display: none; z-index: auto !important;"><lt-div spellcheck="false" class="lt-highlighter__wrapper" style="width: 765.328px !important; height: 644.844px !important; transform: none !important; transform-origin: 382.664px 322.422px !important; zoom: 1 !important;"><lt-div class="lt-highlighter__scroll-element" style="top: 0px !important; left: 0px !important; width: 765px !important; height: 644.844px !important;"><canvas class="lt-highlighter__canvas" width="14" height="20" style="display: none; top: 622px !important; left: 284px !important;"></canvas></lt-div></lt-div></lt-highlighter><div class="elm text-edit gf-elm-left gf-elm-left-md gf-elm-left-sm gf_gs-text-paragraph-1 gf-elm-left-lg gf-elm-justify-xs" data-gemlang="en" data-exc="" data-lt-tmp-id="lt-38138" spellcheck="false" data-gramm="false"><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;"><span style="font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; font-size: 16px; text-align: inherit; letter-spacing: 0px; color: rgb(61, 66, 70);"><br></span></p><p style="font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit !important;">Hi all! my name is Houng, and I am a part of the KS warehouse team. My parents are both from Vietnam, and i was born and raised in the Netherlands.&nbsp;<br></p><p style="font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit !important;"><br></p><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;"><span style="font-weight: bold;">Tell us more about you!</span></p><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;">I love going to the gym, hiking and spending spending quality time with my daughter.&nbsp;</p><p style="font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit !important;"><span style="color: rgb(61, 66, 70);">I am the type of person that loves to get things done. I like to look at problems from a <span style="background-color: rgb(253, 235, 242);">logical prospective</span>. I am always curious about any new skin care brands, and am <span style="background-color: rgb(253, 235, 242);">constantly keeping an eye out</span> of updates or watching You</span><span style="color: rgb(209, 0, 0);">t</span><span style="color: rgb(61, 66, 70);">ube videos on newly released products.&nbsp;</span></p><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;"><br></p><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;"><span style="font-weight: bold;">How did you get to know about Korean skin care?</span></p><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;">In the past I have had my own skin struggles and concerns, and I started using the wrong types of products. My sister introduced to Korean skin care products. After using the products myself, I started to see my <span style="background-color: rgb(253, 235, 242);">skin concerns fading</span>, and became a big fan of the products.&nbsp;</p><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;"><br></p><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;"><span style="font-weight: 700;">What do you like most about your job?</span></p><p style="font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit !important;"><span style="color: rgb(61, 66, 70);">The most fun part about working in the warehouse are hands down the colleagues. We have a <span style="background-color: rgb(253, 235, 242);">great time</span> together which makes the work really enjoyable. I love producing <span style="background-color: rgb(253, 235, 242);">great results</span> with the whole team. I am super proud when we are completely on top of all our orders and make sure our costumers get their orders as quickly as possible and the warehouse looks neat and orderly.</span></p><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;"><br></p><p style="color: rgb(61, 66, 70); font-size: 16px; font-family: &quot;Work Sans&quot;, HelveticaNeue, &quot;Helvetica Neue&quot;, sans-serif; text-align: inherit!important;"><span style="font-weight: bold;">Huong's &nbsp;favourite products:</span></p></div></div></div><div class="gf_column gf_col-lg-4 gf_col-md-4 gf_col-xs-12 gf_col-sm-12" id="c-1677661031133" data-id="1677661031133"><div data-label="Image" data-key="image" data-atomgroup="element" id="e-1677751289614" class="element-wrap" data-icon="gpicon-image" data-ver="1.0" data-id="1677751289614" data-resolution="3000x3000" style=""><div class="elm gf-elm-center gf_elm-left-xs gf-elm-center-md gf-elm-center-sm gf-elm-center-xs gf-elm-center-lg" data-exc=""><img src="https://ucarecdn.com/198f80ec-2ec6-4758-8b4f-5cac7e7a6b86/-/format/auto/-/preview/3000x3000/-/quality/lighter/Huong-_pink_.jpg" alt="" class="gf_image" data-gemlang="en" data-width="75%" data-height="auto" title="" width="800" height="800" natural-width="800" natural-height="800"></div></div></div></div>{% render 'article.gem-557435879487-1-template' %}
