{% liquid
  assign bl_stts = block.settings
  assign heading = bl_stts.heading
  assign color_scheme = bl_stts.color_scheme
  assign accordion_item_dividers = bl_stts.accordion_item_dividers
%}

{% if collection.metafields.custom.sub_collection.value != blank %}
  <div
    class="sub-collection-block size-style{% if accordion_item_dividers == true %} menu--item-dividers{% endif %}"
    style="{% render 'size-style', settings: bl_stts %}"
  >
    <div
      class="
        sub-collection-details
        menu__details
        spacing-style
        {% if block.settings.inherit_color_scheme == false %}color-scheme-custom{% endif %}
      "
      style="
        --spacing--size: {{ bl_stts.menu_spacing }}px;
        {% render 'spacing-style', settings: bl_stts %}
        {% if block.settings.inherit_color_scheme == false %}
          {% render 'color-scheme-style', settings: block.settings %}
        {% endif %}
      "
      {{ block.shopify_attributes }}
    >
      <div class="details-content">
        {% if collection.metafields.custom.sub_collection.value != blank %}
          {% if bl_stts.show_image %}
            <span class="menu__heading__default">{{ heading }}</span>

            <ul
              class="list-unstyled direction--row mobile-row"
              style="--font-heading--size: {{ bl_stts.heading_font_size }}; --font-link--size: {{ bl_stts.link_font_size }};"
            >
              {% for item in collection.metafields.custom.sub_collection.value %}
                <li class="menu__item has-image">
                  <a class="flex flex-column w-full" href="{{ item.url }}">
                    {% if item.featured_image %}
                      <img {% if settings.enable_lazyload %}data-{% endif %}srcset="{{ item.featured_image | image_url: width: 130 }}" src="{{ item.featured_image | image_url: width: 130 }}" alt="{{ item.featured_image.alt | default: shop.name | escape }}"{% if settings.enable_lazyload %} loading="lazy"{% endif %} width="{{item.featured_image.width}}" height="auto">
                    {% else %}
                      {{ 'collection-' | append: forloop.index | placeholder_svg_tag }}
                    {% endif %}
                    <span class="link--hover-underline">{{ item.title }}</span>
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% else %}
            <ul
              class="
                list-unstyled
                direction--row
                mobile-row
              "
              style="--font-heading--size: {{ bl_stts.heading_font_size }}; --font-link--size: {{ bl_stts.link_font_size }};"
            >
              <li class="menu__heading__default">{{ heading }}</li>
              {% for item in collection.metafields.custom.sub_collection.value %}
                <li class="menu__item">
                  <a class="link--hover-underline" href="{{ item.url }}">
                    {{ item.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

