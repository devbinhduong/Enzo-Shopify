{%- liquid
  assign card_article = block.settings.article 
-%}

{%- capture tag_item_style -%}
  {% render 'border-override', settings: block.settings %}
  {% if block.settings.custom_card_border %} 
    --border-color: {{ block.settings.card_border_color }};
  {% endif %}
  padding: 0.8rem;
{%- endcapture -%}

<div class="blog-post-tag {%- if block.settings.type_preset != '' -%}{{ block.settings.type_preset }}{%- endif -%}">
  {%- if card_article -%}
    <ul class="blog-post-tag__list list-unstyled flex flex-wrap" style="gap: 1rem;">
      {%- for tag in card_article.tags -%}
        <li class="blog-post-tag__item border-style" style="{{ tag_item_style }}">
          {% render 'text', fallback_text: tag, block: block %}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

